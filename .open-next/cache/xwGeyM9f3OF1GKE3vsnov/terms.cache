null,{\"className\":\"max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24 relative z-10\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-12 pb-8 border-b border-zinc-200 dark:border-zinc-900/60\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-[9px] font-bold tracking-widest uppercase text-zinc-500 dark:text-zinc-650 border border-zinc-200 dark:border-zinc-800 px-2 py-0.5 rounded-full bg-zinc-50 dark:bg-transparent\",\"children\":\"Legal\"}]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl font-bold tracking-tight text-zinc-950 dark:text-zinc-50 mb-3\",\"children\":\"Terms of Service\"}],[\"$\",\"p\",null,{\"className\":\"text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed\",\"children\":\"Please read these terms carefully before using PulsePing. By accessing the service, you agree to the policies outlined below.\"}],[\"$\",\"p\",null,{\"className\":\"text-zinc-400 dark:text-zinc-700 text-[11px] mt-4 font-mono\",\"children\":\"Effective: January 1, 2026 · Version 1.0\"}]]}],[\"$\",\"div\",null,{\"className\":\"space-y-8\",\"children\":[[\"$\",\"div\",\"1. Acceptance of Terms\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"1. Acceptance of Terms\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"By accessing or using PulsePing (\\\"Service\\\"), you agree to be bound by these Terms of Service. If you do not agree to these terms, you may not use the Service. These terms apply to all users, including those on free and paid account tiers.\"}]]}],[\"$\",\"div\",\"2. Service Description\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"2. Service Description\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"PulsePing provides automated HTTP endpoint monitoring, uptime logging, and alert notification services. The Service operates serverless polling pipelines that periodically send HTTP requests to registered endpoint URLs and records response telemetry including status codes and latency measurements.\"}]]}],[\"$\",\"div\",\"3. Account Registration\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"3. Account Registration\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"Access to PulsePing requires authentication via Clerk. You are responsible for maintaining the security of your credentials and for all activity under your account. You must provide accurate information during registration. Accounts may not be shared or transferred without express written permission.\"}]]}],[\"$\",\"div\",\"4. Monitor Stream Limits\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"4. Monitor Stream Limits\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"Free Tier accounts may register up to two (2) active monitor streams. Pro Tier accounts support unlimited monitor stream registrations. Monitors that consistently fail validation or target private IP ranges, localhost addresses, or internal network endpoints may be suspended without notice to protect shared infrastructure. Frequency of polling is fixed at 10-minute intervals for all plans.\"}]]}],[\"$\",\"div\",\"5. Acceptable Use Policy\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"5. Acceptable Use Policy\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"You agree not to use the Service to monitor endpoints you do not own or have explicit permission to test. You may not use PulsePing to conduct load testing, vulnerability scanning, or any form of network probing beyond simple HTTP health checks. Any abuse of the monitoring infrastructure may result in immediate account termination.\"}]]}],[\"$\",\"div\",\"6. Billing and Subscription\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"6. Billing and Subscription\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"Pro Tier subscriptions are billed monthly at the rate published on the pricing page at the time of purchase. All payments are processed securely via Razorpay. Subscription fees are non-refundable except as required by applicable law. You may cancel your subscription at any time; cancellation takes effect at the end of the current billing period. Downgrades to Free Tier will enforce stream limits at the start of the next billing cycle.\"}]]}],[\"$\",\"div\",\"7. Service Availability\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"7. Service Availability\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"PulsePing targets 99.5% monthly uptime for its core monitoring infrastructure. Scheduled maintenance windows will be announced via the status page at /status. We are not liable for missed alert notifications caused by third-party webhook delivery failures, including Discord API outages. Monitor polling may be delayed during infrastructure maintenance periods.\"}]]}],[\"$\",\"div\",\"8. Data Retention\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"8. Data Retention\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"PingLog entries (response records) are retained for 90 days for Free Tier accounts and 12 months for Pro Tier accounts, after which they are automatically purged. Registered endpoint URLs and Discord webhook URLs are retained for the lifetime of the account. Account data is deleted within 30 days of account termination.\"}]]}],[\"$\",\"div\",\"9. Intellectual Property\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"9. Intellectual Property\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"All content, code, designs, and trademarks associated with PulsePing are the exclusive property of their respective owners. You retain ownership of any endpoints you register. You grant PulsePing a limited license to access registered URLs solely for the purpose of performing monitor checks.\"}]]}],[\"$\",\"div\",\"10. Limitation of Liability\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"10. Limitation of Liability\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"PulsePing is provided on an \\\"as-is\\\" and \\\"as-available\\\" basis. To the fullest extent permitted by law, we disclaim all warranties, express or implied. We are not liable for any indirect, incidental, consequential, or punitive damages arising from your use of the Service. Our total aggregate liability shall not exceed the amount you paid for the Service in the 3 months preceding the claim.\"}]]}],[\"$\",\"div\",\"11. Termination\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"11. Termination\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"We reserve the right to suspend or terminate your account at any time for violations of these terms, abuse of infrastructure, or non-payment. You may terminate your account at any time by contacting support. Upon termination, your data will be retained for 30 days before deletion.\"}]]}],[\"$\",\"div\",\"12. Changes to Terms\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"12. Changes to Terms\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"We may update these Terms of Service from time to time. Significant changes will be communicated via email or an in-app notice. Your continued use of the Service after such notice constitutes acceptance of the updated terms.\"}]]}],[\"$\",\"div\",\"13. Governing Law\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"13. Governing Law\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"These terms are governed by the laws of India. Any disputes arising from these terms shall be subject to the exclusive jurisdiction of the competent courts of India.\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-zinc-200 dark:border-zinc-900/60 mt-12 pt-8\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-[11px] text-zinc-500 dark:text-zinc-700\",\"children\":[\"Questions about these terms? Contact us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:legal@pulseping.io\",\"className\":\"text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition duration-150\",\"children\":\"legal@pulseping.io\"}]]}]}]]}],[\"$\",\