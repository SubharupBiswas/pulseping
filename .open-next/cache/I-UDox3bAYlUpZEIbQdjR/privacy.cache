",null,{\"className\":\"sticky top-0 z-50 border-b border-zinc-200 dark:border-zinc-900/60 bg-white/75 dark:bg-[#030303]/60 backdrop-blur-xl transition-colors duration-250\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between\",\"children\":[[\"$\",\"$L2\",null,{\"href\":\"/\",\"className\":\"flex items-center gap-2.5 group pointer-events-auto\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-5 h-5 rounded-md bg-zinc-950 dark:bg-zinc-50 flex items-center justify-center shadow-[0_0_10px_rgba(255,255,255,0.06)] group-hover:bg-zinc-800 dark:group-hover:bg-zinc-200 transition duration-150\",\"children\":[\"$\",\"div\",null,{\"className\":\"w-1.5 h-1.5 rounded-full bg-zinc-50 dark:bg-zinc-950\"}]}],[\"$\",\"span\",null,{\"className\":\"font-semibold text-[13px] tracking-tight text-zinc-900 dark:text-zinc-100\",\"children\":\"PulsePing\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4\",\"children\":[[\"$\",\"$L3\",null,{}],[\"$\",\"$L2\",null,{\"href\":\"/terms\",\"className\":\"text-[11px] text-zinc-500 hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-300 transition duration-150\",\"children\":\"Terms\"}],[\"$\",\"$L2\",null,{\"href\":\"/status\",\"className\":\"text-[11px] text-zinc-500 hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-300 transition duration-150\",\"children\":\"Status\"}],[\"$\",\"$L2\",null,{\"href\":\"/dashboard\",\"className\":\"text-[11px] font-semibold bg-zinc-900 hover:bg-zinc-800 text-zinc-250 border border-zinc-800 px-3 py-1.5 rounded-lg transition duration-150 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.03)]\",\"children\":\"Console\"}]]}]]}]}],[\"$\",\"main\",null,{\"className\":\"max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24 relative z-10\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-12 pb-8 border-b border-zinc-200 dark:border-zinc-900/60\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-[9px] font-bold tracking-widest uppercase text-zinc-500 dark:text-zinc-650 border border-zinc-200 dark:border-zinc-800 px-2 py-0.5 rounded-full bg-zinc-50 dark:bg-transparent\",\"children\":\"Legal\"}]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 mb-3\",\"children\":\"Privacy Policy\"}],[\"$\",\"p\",null,{\"className\":\"text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed\",\"children\":\"This policy outlines how PulsePing processes user authentication information, endpoint targets, and monitoring log archives.\"}],[\"$\",\"p\",null,{\"className\":\"text-zinc-400 dark:text-zinc-700 text-[11px] mt-4 font-mono\",\"children\":\"Effective: January 1, 2026 · Version 1.0\"}]]}],[\"$\",\"div\",null,{\"className\":\"space-y-8\",\"children\":[[\"$\",\"div\",\"1. Information We Collect\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"1. Information We Collect\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"We collect information necessary to perform uptime monitoring and alert notifications. This includes:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"User Profile Data: Email addresses, user IDs, and metadata provided by Clerk during user sign-in processes.\"}],[\"$\",\"li\",\"1\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Registered Target Data: Target URLs and optional Discord webhook URL strings registered to user monitoring channels.\"}],\"$L4\",\"$L5\"]}]]}],\"$L6\",\"$L7\",\"$L8\",\"$L9\",\"$La\",\"$Lb\",\"$Lc\",\"$Ld\",\"$Le\",\"$Lf\",\"$L10\"]}],\"$L11\"]}],\"$L12\"]}],null,\"$L13\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"I-UDox3bAYlUpZEIbQdjR\"}\n4:[\"$\",\"li\",\"2\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Telemetry Log Records: Status codes, HTTP response headers, check latencies, check timestamps, and target accessibility metrics logged to PostgreSQL.\"}]\n5:[\"$\",\"li\",\"3\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Billing Details: Subscription status, payment references, and plan limits processed securely by Razorpay. We do not store raw card numbers.\"}]\n6:[\"$\",\"div\",\"2. How We Use Information\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"2. How We Use Information\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"Information is processed exclusively to:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Instantiate and execute automated endpoint check cron tasks.\"}],[\"$\",\"li\",\"1\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Dispatch Markdown failure embeds to your Discord channel targets when health rules are breached.\"}],[\"$\",\"li\",\"2\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Generate the dashboard console charts, stats matrices, and check histories.\"}],[\"$\",\"li\",\"3\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Manage subscription records, verify signatures, and upgrade plan capacities.\"}],[\"$\",\"li\",\"4\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Verify user authorization inside monitors server actions.\"}]]}]]}]\n7:[\"$\",\"div\",\"3. Service Infrastructure and Database Storage\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"3. Service Infrastructure and Database Storage\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"Data is stored durably on Neon PostgreSQL servers utilizing Prisma 7. The database records are protected by encryption at rest. Internal database queries are strictly constrained to ensure that users may only view telemetry data matching their authenticated Clerk identity signature.\"}],\"$undefined\"]}]\n8:[\"$\",\"div\",\"4. Telemetry Log Retention and Purges\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"4. Telemetry Log Retention and Purges\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"Uptime logs (PingLogs) are stored for:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Free Tier: 90 days of check history, after which logs are permanently deleted.\"}],[\"$\",\"li\",\"1\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Pro Tier: 365 days of check history, allowing for long-term SLA reporting.\"}],[\"$\",\"li\",\"2\",{\"className\":\"text-[13px] text-zinc-550 dark:text-zinc-450 leading-[1.7]\",\"children\":\"Deleted Monitors: When a website monitor is deleted, all dependent PingLog entries are purged from the database immediately to preserve integrity.\"}]]}]]}]\n9:[\"$\",\"div\",\"5. Security notice and Warning Interception\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"5. Security notice and Warning Interception\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"To protect your operational metrics, all dashboard and server pipelines intercept database driver event outputs. Database warnings are caught and sanitized before logs are written to external diagnostic consoles, preventing credentials or configurations from leaking.\"}],\"$undefined\"]}]\na:[\"$\",\"div\",\"6. Billing and Checkout Security\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"6. Billing and Checkout Security\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"All payment operations are handled by Razorpay's PCI-DSS compliant standard web checkout framework. Under sandbox and production profiles, checkout fields utilize dynamic data sanitization: customer contact details inside prefill objects are restricted to mock credentials (9876543210 / test.premium@pulseping.io) to protect your real profile information.\"}],\"$undefined\"]}]\nb:[\"$\",\"div\",\"7. Cookies and Authentication Identifiers\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"7. Cookies and Authentication Identifiers\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"We do not set tracking or advertising cookies. Access tokens and session keys are managed natively by Clerk using secure HTTP-only cookie parameters to validate route routing configurations.\"}],\"$undefined\"]}]\nc:[\"$\",\"div\",\"8. Data Sharing and Third-Party API Hooks\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"8. Data Sharing and Third-Party API Hooks\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"We do not sell user data. Target check metrics are dispatched to third-party endpoints (e.g. Discord servers) solely when a webhook URL is configured by the user. These requests are sent over HTTPS with payload signatures.\"}],\"$undefined\"]}]\nd:[\"$\",\"div\",\"9. Your Rights and Access Controls\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"9. Your Rights and Access Controls\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"You have the right to access, edit, or delete any monitors registered to your account at any time via the console. If you wish to delete your entire profile and database record archive, you may contact support.\"}],\"$undefined\"]}]\ne:[\"$\",\"div\",\"10. Children's Privacy\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"10. Children's Privacy\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"PulsePing does not knowingly collect or solicit personal data from children. The Service is restricted to developers and professionals managing online endpoints.\"}],\"$undefined\"]}]\nf:[\"$\",\"div\",\"11. Changes to this Privacy Policy\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"11. Changes to this Privacy Policy\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"We may revise this policy periodically. The version marker will be updated, and significant updates will be communicated on the homepage footer status bar or via email.\"}],\"$undefined\"]}]\n10:[\"$\",\"div\",\"12. Contact Information\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[13px] font-bold text-zinc-800 dark:text-zinc-200 tracking-tight mb-3\",\"children\":\"12. Contact Information\"}],[\"$\",\"p\",null,{\"className\":\"text-[13px] text-zinc-500 dark:text-zinc-400 leading-[1.8]\",\"children\":\"For questions about this policy or database practices, contact support at legal@pulseping.io.\"}],\"$undefined\"]}]\n11:[\"$\",\"div\",null,{\"className\":\"border-t border-zinc-200 dark:border-zinc-900/60 mt-12 pt-8\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-[11px] text-zinc-500 dark:text-zinc-700\",\"children\":[\"Questions about your database files or data logs? Contact us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:legal@pulseping.io\",\"className\":\"text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition duration-150\",\"children\":\"legal@pulseping.io\"}]]}]}]\n12:[\"$\",\"footer\",null,{\"className\":\"border-t border-zinc-200 dark:border-zinc-900/40 bg-zinc-50/50 dark:bg-transparent transition-colors duration-250\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row justify-between items-center gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-[11px] text-zinc-500 dark:text-zinc-650\",\"children\":\"PulsePing © 2026\"}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-5\",\"children\":[[\"$\",\"$L2\",null,{\"href\":\"/terms\",\"className\":\"text-[11px] text-zinc-500 hover:text-zinc-950 dark:text-zinc-500 dark:hover:text-zinc-300 transition duration-150\",\"children\":\"Terms\"}],[\"$\",\"$L2\",null,{\"href\":\"/privacy\",\"className\":\"text-[11px] text-zinc-500 hover:text-zinc-950 dark:text-zinc-500 dark:hover:text-zinc-300 transition duration-150\",\"children\":\"Privacy\"}],[\"$\",\"$L2\",null,{\"href\":\"/status\",